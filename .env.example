NODE_ENV=development

# Auth.js — generate with: openssl rand -base64 33
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# Database (local: Postgres via 'brew services start postgresql@16'; prod: Hetzner)
DATABASE_URL=postgres://USER@localhost:5432/klick

# Default tenant slug used when no subdomain is present
DEFAULT_TENANT_SLUG=default

# Mail
MAIL_FROM="Klick <noreply@klick.local>"
# Production: Brevo SMTP (EU region) — set when leaving P0
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_USER=
# BREVO_SMTP_PASS=

# Vault encryption: 32-byte master KEK, base64-encoded. Prod: KMS-backed.
# Generate dev key with: openssl rand -base64 32
VAULT_KEK_BASE64=

# Object storage (local: MinIO via 'brew services start minio'; prod: Hetzner)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=klick
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# AI providers (P2 onward)
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=
