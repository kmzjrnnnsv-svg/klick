# ── Server ──────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Auth (generate with: openssl rand -base64 33) ───────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ── Database ────────────────────────────────────────────────────────────────
# Local: Postgres via 'brew services start postgresql@16'
# Prod:  Postgres on the Hetzner host (same instance, separate DB + user)
DATABASE_URL=postgres://USER@localhost:5432/klick

# ── Tenant ──────────────────────────────────────────────────────────────────
# Default slug used when no subdomain is present
DEFAULT_TENANT_SLUG=default

# ── Mail ────────────────────────────────────────────────────────────────────
# Reihenfolge der Zustellung:
#   1. RESEND_API_KEY   → HTTPS-API (umgeht SMTP-Firewalls, empfohlen für Hetzner)
#   2. SMTP_HOST        → klassisches SMTP über Nodemailer
#   3. ohne beides      → Magic-Link erscheint im Server-Log (Dev-Fallback)
#
# MAIL_FROM ist Pflicht — die Domain muss zur Versand-Adresse passen.
# Bei Resend:   MAIL_FROM-Domain in app.resend.com unter "Domains" verifizieren.
# Bei PrivateEmail: MAIL_FROM-Domain muss zum SMTP_USER-Postfach gehören.
MAIL_FROM="Klick <noreply@klick.local>"

# Resend (empfohlen): Account auf resend.com, Domain verifizieren, API-Key holen.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SMTP-Pfad (PrivateEmail/Brevo/etc.). Port 587 STARTTLS bevorzugen — Port 465
# wird von Hetzner und vielen Cloud-Providern outbound geblockt.
# SMTP_HOST=mail.privateemail.com
# SMTP_PORT=587
# SMTP_USER=noreply@deinedomain.de
# SMTP_PASS=DeinPostfachPasswort

# ── Vault Encryption (generate with: openssl rand -base64 32) ───────────────
# 32-byte master KEK, base64-encoded. Production: KMS-backed.
VAULT_KEK_BASE64=

# ── Object Storage ──────────────────────────────────────────────────────────
# Local: MinIO via 'brew services start minio'
# Prod:  Hetzner Object Storage (eu-central) or self-hosted MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=klick
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── AI Providers ────────────────────────────────────────────────────────────
# Without ANTHROPIC_API_KEY the app falls back to a deterministic Mock provider.
# ANTHROPIC_API_KEY=
# VOYAGE_API_KEY=

# ── Demo Login ──────────────────────────────────────────────────────────────
# Set to "true" in dev/demo to expose four one-click logins on /login
# (admin, company, headhunter, candidate). NEVER enable on a real production
# tenant — the route trusts the role param without further authn.
# Companion data: `pnpm db:seed` creates the matching users.
# ENABLE_DEMO_LOGIN=true

# ── Microsoft SSO (optional) ────────────────────────────────────────────────
# Aktiviert "Mit Microsoft anmelden" auf /login. Erfordert eine App-
# Registrierung im Azure Portal:
#   1. portal.azure.com → Microsoft Entra ID → App registrations → New
#   2. Redirect URI (Web): https://<deine-domain>/api/auth/callback/microsoft-entra-id
#   3. Lokal zusätzlich:    http://localhost:3000/api/auth/callback/microsoft-entra-id
#   4. Certificates & secrets → New client secret → Wert kopieren (nur einmal sichtbar)
#   5. Overview → Application (client) ID + Directory (tenant) ID kopieren
#
# Tenant-ID-Optionen:
#   "common"        — alle Microsoft-Konten (Work + privat)
#   "organizations" — alle Work/School-Accounts (kein privat)
#   "<guid>"        — nur deine Organisation (höchste Sicherheit, empfohlen für B2B)
#
# Nur wenn alle drei Variablen gesetzt sind, erscheint der SSO-Button.
# AZURE_AD_CLIENT_ID=
# AZURE_AD_CLIENT_SECRET=
# AZURE_AD_TENANT_ID=
